# GPU server connection
IRODORI_REMOTE_HOST=user@hostname
IRODORI_SERVER_PORT=8923
RVC_SERVER_PORT=8924

# Windows-side paths (used by deploy scripts)
IRODORI_TTS_DIR=C:\path\to\Irodori-TTS
APPLIO_DIR=C:\path\to\Applio

# Voice bank data
VOICE_BANK_DIR=./data/voice_banks

# Cache
CACHE_DIR=./data/cache
CACHE_MAX_SIZE_GB=20
